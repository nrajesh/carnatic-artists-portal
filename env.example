# =============================================================================
# Artist Discovery Portal - Environment Variables (template)
# Copy to `.env` or `.env.local` and fill in values. Files matching `.env*` are
# gitignored - this template is committed as `env.example` (no leading dot).
# NEVER commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# Pooled URL: Neon dashboard → Connection pooling ON.
# Direct URL: pooling OFF - used by Prisma migrate (schema directUrl).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Email (Resend)
# RESEND_API_KEY: API key from resend.com (scoped to a verified domain).
# RESEND_FROM_EMAIL: From address on your verified Resend domain. Must match a
#   domain you have verified in Resend, otherwise sends fail. If unset, the
#   code default (noreply@artist-discovery.example) is used - override for your
#   verified Resend domain in production.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Web Push (VAPID)
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=BExamplePublicKeyBase64UrlEncoded
VAPID_PRIVATE_KEY=ExamplePrivateKeyBase64UrlEncoded
VAPID_SUBJECT=mailto:admin@example.com

# -----------------------------------------------------------------------------
# Registration (no upload to this app)
# -----------------------------------------------------------------------------
# Profile and banner images on /register are optional HTTPS URLs only (paste a link).
# They are not uploaded to R2 by the registration API.

# -----------------------------------------------------------------------------
# Cloudflare R2
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=artist-discovery-portal
R2_PUBLIC_URL=https://assets.example.com

# -----------------------------------------------------------------------------
# KV (sessions / edge)
# -----------------------------------------------------------------------------
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your_kv_rest_api_token

# -----------------------------------------------------------------------------
# PostHog (optional)  -  see /privacy for end-user disclosure; Session Replay envs below.
# End-user analytics: GET https://<your-app-host>/privacy/opt-out (sets adp_analytics_opt_out=1; legacy ph_opt_out cleared); GET .../privacy/opt-in (clears opt-out cookies + resumes capture).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# App UI origin (not the ingest API). EU: https://eu.posthog.com - US: https://us.posthog.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com
# Browser ingest API - used in `next dev` only (direct to Cloud). US: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_INGEST_HOST=https://eu.i.posthog.com
POSTHOG_HOST=https://posthog.internal.example.com
POSTHOG_ADMIN_PATH=/internal/replace-with-32-plus-random-chars
# Session replay: omit or leave empty  -  do not pass disable_session_recording in the SDK (see PostHog troubleshooting).
# Set to false only to opt out client-side: NEXT_PUBLIC_POSTHOG_ENABLE_RECORDING=false
# https://posthog.com/docs/session-replay/troubleshooting#recordings-are-not-being-captured
NEXT_PUBLIC_POSTHOG_ENABLE_RECORDING=
# Local dev: session replay is off by default (avoids rrweb worker / blob source-map console noise). Set true to record localhost.
NEXT_PUBLIC_POSTHOG_RECORDING_IN_DEV=
# Feature flags: create a boolean flag `artist-collabs-ratings` in PostHog. Optional env override (true/false) bypasses PostHog for collabs + ratings UI.
# POSTHOG_FLAG_ARTIST_COLLABS_RATINGS=false
# NEXT_PUBLIC_POSTHOG_FLAG_ARTIST_COLLABS_RATINGS=false

# -----------------------------------------------------------------------------
# App (session + URLs)
# -----------------------------------------------------------------------------
SESSION_SECRET=change-me-to-a-random-32-char-string-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Deployment (multi-region)
# -----------------------------------------------------------------------------
# DEPLOYMENT_TIMEZONE: IANA zone for "today" (featured artist, DailyFeatured dates).
# Optional - if unset, derived from DEPLOYMENT_REGION via country→timezone data (single-zone countries).
# Required when DEPLOYMENT_REGION has multiple timezones (e.g. US, AU). Copy labels use Intl (e.g. CET).
# DEPLOYMENT_TIMEZONE=Europe/City
DEPLOYMENT_REGION=XX
DEPLOYMENT_NAME=Find Artists
DEPLOYMENT_LOCALE_PRIMARY=en
DEPLOYMENT_LOCALE_SECONDARY=
# Optional. Leave blank to disable deployment GeoJSON-derived suggestions.
DEPLOYMENT_MAP_GEOJSON_URL=
# Optional JSON array of city labels used in forms and filters.
# If omitted, city suggestions stay empty. Non-city labels can derive options from DEPLOYMENT_MAP_GEOJSON_URL.
# DEPLOYMENT_LOCATION_OPTIONS=["Amsterdam","Hilversum","Nijmegen"]
DEPLOYMENT_LOCATION_OPTIONS=
# Optional copy labels for the deployment's city field.
# DEPLOYMENT_LOCATION_LABEL_SINGULAR=city
# DEPLOYMENT_LOCATION_LABEL_PLURAL=cities
DEPLOYMENT_LOCATION_LABEL_SINGULAR=
DEPLOYMENT_LOCATION_LABEL_PLURAL=
# Optional JSON array of GeoJSON property keys to read labels from, in priority order.
# DEPLOYMENT_MAP_GEOJSON_LABEL_KEYS=["name","label"]
DEPLOYMENT_MAP_GEOJSON_LABEL_KEYS=
# Optional JSON object mapping GeoJSON labels to stored artist location values.
# DEPLOYMENT_LOCATION_ALIASES={"Capital District":"Capital"}
DEPLOYMENT_LOCATION_ALIASES=
DEPLOYMENT_BRANDING_LOGO_URL=/assets/logo.svg
DEPLOYMENT_COLOR_OVERRIDES=
