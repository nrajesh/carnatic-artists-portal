# =============================================================================
# Carnatic Artist Portal — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local or any file containing real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# Use the pooled connection string for serverless functions.
# Use the direct (unpooled) connection string for Prisma migrations.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Email (Resend)
# Used for sending magic-link authentication emails and notifications.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID)
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URI identifying the sender.
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=BExamplePublicKeyBase64UrlEncoded
VAPID_PRIVATE_KEY=ExamplePrivateKeyBase64UrlEncoded
VAPID_SUBJECT=mailto:admin@example.com

# -----------------------------------------------------------------------------
# Object Storage (Cloudflare R2)
# R2 is S3-compatible; the endpoint is https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL is the public base URL for serving stored assets (e.g. via a custom domain).
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=carnatic-artist-portal
R2_PUBLIC_URL=https://assets.example.com

# -----------------------------------------------------------------------------
# KV Store (Cloudflare KV or Vercel KV)
# Used for session caching and edge middleware auth checks.
# -----------------------------------------------------------------------------
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your_kv_rest_api_token

# -----------------------------------------------------------------------------
# Deployment Configuration
# These values drive multi-region extensibility (Requirement 16).
# No deployment-specific values should be hard-coded in application source code.
# -----------------------------------------------------------------------------

# Region identifier (e.g. NL, UK, IN)
DEPLOYMENT_REGION=NL

# Portal display name shown in the UI and browser title
DEPLOYMENT_NAME=Carnatic Artist Portal

# Primary UI language code (IETF BCP 47, e.g. en, nl, ta)
DEPLOYMENT_LOCALE_PRIMARY=en

# Secondary UI language code (optional; leave blank if only one language is needed)
DEPLOYMENT_LOCALE_SECONDARY=nl

# Path or URL to the GeoJSON file describing the region's administrative areas.
# For the NL deployment this points to the bundled Netherlands provinces file.
DEPLOYMENT_MAP_GEOJSON_URL=/geo/netherlands-provinces.geojson

# URL to the portal branding logo asset (relative path or absolute URL)
DEPLOYMENT_BRANDING_LOGO_URL=/assets/logo.svg

# Optional JSON string of CSS variable overrides for brand colours.
# Example: {"--color-primary":"#E85D04","--color-accent":"#F48C06"}
# Leave blank to use the default colour palette.
DEPLOYMENT_COLOR_OVERRIDES=
