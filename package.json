    "leaflet": "^1.9.4",
    "next": "^16.2.4",
    "posthog-js": "^1.373.5",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
