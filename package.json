{
  "name": "artist-discovery-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare deploy -- --keep-vars",
    "deploy:cf:full": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:backfill-pii": "tsx scripts/backfill-artist-pii.ts",
    "db:backfill-profile-photos": "tsx scripts/backfill-profile-photos-to-r2.ts",
    "db:set-admin": "tsx scripts/set-artist-admin.ts",
    "db:dedupe-speciality-colors": "tsx scripts/dedupe-speciality-color-pairs.ts"
  },
  "dependencies": {
