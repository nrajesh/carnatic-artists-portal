{
  "name": "carnatic-artist-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare deploy -- --keep-vars",
    "deploy:cf:full": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "6.19.3",
    "@prisma/client": "^6.19.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "countries-and-timezones": "^3.9.0",
    "jose": "^6.2.2",
    "next": "^16.2.4",
    "posthog-js": "^1.368.2",
    "posthog-node": "^5.29.2",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "resend": "^6.10.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.14.10",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.0.1",
    "fast-check": "^3.19.0",
    "postcss": "^8",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.83.0"
  }
}
